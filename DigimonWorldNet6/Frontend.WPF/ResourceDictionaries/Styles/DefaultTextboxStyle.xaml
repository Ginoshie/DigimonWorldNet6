<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:behaviors="clr-namespace:DigimonWorld.Frontend.WPF.Behaviors">
    <Style x:Key="DefaultTextBoxStyle" TargetType="{x:Type TextBox}" BasedOn="{StaticResource {x:Type TextBox}}">
        <Style.Setters>
            <Setter Property="behaviors:ContextMenuBehavior.IsDisabled" Value="True" />
            <Setter Property="FontFamily" Value="{StaticResource Dw1Font}" />
            <Setter Property="Background" Value="#354A5B" />
            <Setter Property="Foreground" Value="#D6D6D8" />
            <Setter Property="BorderBrush" Value="#6987A3" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Height" Value="{StaticResource DefaultTextBoxHeight}" />
            <Setter Property="Margin" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="IsReadOnly" Value="False" />
            <Setter Property="Validation.ErrorTemplate" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border x:Name="ValidationBorder"
                                    BorderBrush="Transparent"
                                    BorderThickness="1">
                                <Border x:Name="OuterBorder"
                                        BorderBrush="#6789A5"
                                        BorderThickness="0,0,2,2">
                                    <Border x:Name="BevelBorder"
                                            BorderBrush="#060100"
                                            BorderThickness="3,3,0,0">
                                        <Border x:Name="InnerBorder"
                                                Background="{TemplateBinding Background}"
                                                Padding="4">
                                            <ScrollViewer x:Name="PART_ContentHost" />
                                        </Border>
                                    </Border>
                                </Border>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="InnerBorder" Property="Background" Value="#567D91" />
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#456A7D" />
                            </Trigger>
                            <Trigger Property="behaviors:LockState.IsLocked" Value="True">
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#D4D604" />
                                <Setter TargetName="BevelBorder" Property="BorderBrush" Value="#D4D604" />
                            </Trigger>
                            <Trigger Property="Validation.HasError" Value="True">
                                <Setter TargetName="ValidationBorder" Property="BorderBrush" Value="Red" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style.Setters>
    </Style>

</ResourceDictionary>