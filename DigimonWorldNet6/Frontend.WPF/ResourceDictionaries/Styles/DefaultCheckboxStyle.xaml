<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:behaviors="clr-namespace:DigimonWorld.Frontend.WPF.Behaviors">

    <Style x:Key="DefaultCheckboxStyle" TargetType="CheckBox">
        <Setter Property="Background" Value="#2E3841" />
        <Setter Property="BorderBrush" Value="#90D9FA" />
        <Setter Property="LayoutTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1.5" ScaleY="1.5" />
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Border x:Name="Box"
                            Width="14" Height="14"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1.5"
                            CornerRadius="2"
                            SnapsToDevicePixels="True">
                        <Rectangle x:Name="Fill"
                                   Margin="2"
                                   Fill="White"
                                   RadiusX="1"
                                   RadiusY="1"
                                   Visibility="Collapsed" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Fill" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="White" />
                        </Trigger>
                        <Trigger Property="behaviors:LockState.IsLocked" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="#D4D604" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
