<UserControl x:Class="DigimonWorld.Frontend.WPF.Windows.Main.UserControls.CheatSheet.UserControls.TechniquesSectionUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:DigimonWorld.Frontend.WPF.Windows.Main.UserControls.CheatSheet.Models"
             xmlns:system="clr-namespace:System;assembly=System.Runtime"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance models:CheatSheetViewModel}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../DataTemplates/MemoryValueRowTemplate.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <system:Double x:Key="IconDimension">28</system:Double>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Image Grid.Row="0" Height="40" HorizontalAlignment="Center"
               Source="/Images/Icons/Labels/techniques-label.png"
               Margin="0,0,0,10" />

        <ItemsControl Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Top" ItemsSource="{Binding TechniqueGroups}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="4" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="0,0,10,8">
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Width="{StaticResource IconDimension}" Height="{StaticResource IconDimension}" BorderBrush="#B0B0B0"
                                    BorderThickness="3,3,0,0" Background="#575C60">
                                <Border BorderBrush="#060100" BorderThickness="0,0,3,3" Padding="2">
                                    <Image Source="{Binding IconPath}" Stretch="Uniform" />
                                </Border>
                            </Border>

                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                       Foreground="#D4D604"
                                       FontSize="15"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />

                            <Border Grid.Column="2" Width="{StaticResource IconDimension}" Height="{StaticResource IconDimension}" BorderBrush="#B0B0B0"
                                    BorderThickness="3,3,0,0" Background="#575C60">
                                <Border BorderBrush="#060100" BorderThickness="0,0,3,3" Padding="2">
                                    <Image Source="{Binding IconPath}" Stretch="Uniform" />
                                </Border>
                            </Border>
                        </Grid>
                        <ItemsControl ItemTemplate="{StaticResource MemoryValueRowTemplate}"
                                      ItemsSource="{Binding Techniques}" />
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>

</UserControl>
