<UserControl x:Class="DigimonWorld.Frontend.WPF.Windows.Main.UserControls.CheatSheet.UserControls.RecruitmentSectionUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:DigimonWorld.Frontend.WPF.Windows.Main.UserControls.CheatSheet.Models"
             xmlns:system="clr-namespace:System;assembly=System.Runtime"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance models:CheatSheetViewModel}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../DataTemplates/ZoneRowTemplate.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <system:Double x:Key="ColumnWidth">310</system:Double>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Image Grid.Row="0" Height="40" HorizontalAlignment="Center"
               Source="/Images/Icons/Labels/recruitments-label.png"
               Margin="0,0,0,10" />

        <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ItemsControl Grid.Column="0" Width="{StaticResource ColumnWidth}" Margin="0,0,15,0"
                          ItemsSource="{Binding RecruitmentZonesLeft}"
                          ItemTemplate="{StaticResource ZoneRowTemplate}" />

            <ItemsControl Grid.Column="1" Width="{StaticResource ColumnWidth}"
                          ItemsSource="{Binding RecruitmentZonesRight}"
                          ItemTemplate="{StaticResource ZoneRowTemplate}" />
        </Grid>
    </Grid>

</UserControl>
