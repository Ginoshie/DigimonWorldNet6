<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:models="clr-namespace:DigimonWorld.Frontend.WPF.Windows.Main.UserControls.CheatSheet.Models">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="RecruitmentRowTemplate.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <DataTemplate x:Key="ZoneRowTemplate" DataType="{x:Type models:RecruitmentZoneViewModel}">
        <Grid Margin="0,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{Binding Name}"
                       Foreground="#D4D604"
                       FontSize="13"
                       TextAlignment="Right"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />

            <ItemsControl Grid.Column="1" ItemTemplate="{StaticResource RecruitmentRowTemplate}"
                          ItemsSource="{Binding Recruitments}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </Grid>
    </DataTemplate>

</ResourceDictionary>
