<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:behaviors="clr-namespace:DigimonWorld.Frontend.WPF.Behaviors"
                    xmlns:conversion="clr-namespace:DigimonWorld.Frontend.WPF.Conversion"
                    xmlns:models="clr-namespace:DigimonWorld.Frontend.WPF.Windows.Main.UserControls.CheatSheet.Models"
                    xmlns:system="clr-namespace:System;assembly=System.Runtime">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/ResourceDictionaries/Styles/ToolTips/DefaultTooltipRightStyle.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <conversion:DigimonNameToIconPathConverter x:Key="DigimonNameToIconPath" />

    <system:Double x:Key="ButtonDimension">37</system:Double>

    <DataTemplate x:Key="RecruitmentRowTemplate" DataType="{x:Type models:MemoryValueViewModel}">
        <ToggleButton IsChecked="{Binding Value, Mode=TwoWay}"
                      Width="{StaticResource ButtonDimension}" Height="{StaticResource ButtonDimension}" Margin="2"
                      Cursor="Hand" Focusable="False">
            <ToggleButton.ToolTip>
                <ToolTip Style="{StaticResource DefaultToolTipRightStyle}">
                    <TextBlock Text="{Binding Label}" />
                </ToolTip>
            </ToggleButton.ToolTip>
            <ToggleButton.Template>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="OuterFrame" BorderBrush="#B0B0B0" BorderThickness="3,3,0,0" Background="#575C60">
                        <Border x:Name="InnerFrame" BorderBrush="#060100" BorderThickness="0,0,3,3" Padding="2">
                            <Image x:Name="Icon"
                                   Source="{Binding Label, Converter={StaticResource DigimonNameToIconPath}}"
                                   Stretch="Uniform" Opacity="0.5" />
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Icon" Property="Opacity" Value="1.0" />
                        </Trigger>
                        <Trigger Property="behaviors:LockState.IsLocked" Value="True">
                            <Setter TargetName="OuterFrame" Property="BorderBrush" Value="#D4D604" />
                            <Setter TargetName="InnerFrame" Property="BorderBrush" Value="#D4D604" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </ToggleButton.Template>
        </ToggleButton>
    </DataTemplate>

</ResourceDictionary>