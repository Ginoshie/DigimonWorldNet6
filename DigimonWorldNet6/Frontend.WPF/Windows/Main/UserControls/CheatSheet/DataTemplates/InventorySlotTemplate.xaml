<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:models="clr-namespace:DigimonWorld.Frontend.WPF.Windows.Main.UserControls.CheatSheet.Models"
                    xmlns:validation="clr-namespace:DigimonWorld.Frontend.WPF.Validation"
                    xmlns:c="clr-namespace:DigimonWorld.Frontend.WPF.Constants">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/ResourceDictionaries/Styles/DefaultTextboxStyle.xaml" />
        <ResourceDictionary Source="/ResourceDictionaries/Styles/DefaultFocusStyle.xaml" />
        <ResourceDictionary Source="/ResourceDictionaries/Styles/DefaultComboboxStyle.xaml" />
        <ResourceDictionary Source="/ResourceDictionaries/Styles/ToolTips/DefaultTooltipRightStyle.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <DataTemplate x:Key="InventorySlotTemplate" DataType="{x:Type models:InventorySlotViewModel}">
        <Grid Margin="0,1" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="28" />
                <ColumnDefinition Width="50" />
                <ColumnDefinition Width="140" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{Binding SlotNumber}" VerticalAlignment="Center" HorizontalAlignment="Center" />

            <TextBox Grid.Column="1" Margin="2,1" FocusVisualStyle="{StaticResource DefaultFocusStyle}"
                     HorizontalContentAlignment="Center"
                     Style="{StaticResource DefaultTextBoxStyle}">
                <TextBox.ToolTip>
                    <ToolTip Style="{StaticResource DefaultToolTipRightStyle}">
                        <TextBlock Text="{x:Static c:CheatSheetInputInfo.ItemAmountTooltip}" />
                    </ToolTip>
                </TextBox.ToolTip>
                <TextBox.Text>
                    <Binding Path="ItemAmount.Value" UpdateSourceTrigger="LostFocus">
                        <Binding.ValidationRules>
                            <validation:NumericRangeValidationRule Minimum="{x:Static c:CheatSheetInputInfo.ITEM_AMOUNT_MIN}" Maximum="{x:Static c:CheatSheetInputInfo.ITEM_AMOUNT_MAX}" ValidationStep="RawProposedValue" />
                        </Binding.ValidationRules>
                    </Binding>
                </TextBox.Text>
            </TextBox>

            <ComboBox Grid.Column="2" Margin="2,1" VerticalAlignment="Center"
                      HorizontalContentAlignment="Center"
                      Style="{StaticResource DefaultComboboxStyle}"
                      ItemsSource="{x:Static models:InventoryItemCatalog.Items}"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Id"
                      SelectedValue="{Binding ItemType.Value, Mode=TwoWay}">
                <ComboBox.ToolTip>
                    <ToolTip Style="{StaticResource DefaultToolTipRightStyle}">
                        <TextBlock Text="{x:Static c:CheatSheetInputInfo.ItemTypeTooltip}" />
                    </ToolTip>
                </ComboBox.ToolTip>
            </ComboBox>
        </Grid>
    </DataTemplate>

</ResourceDictionary>
