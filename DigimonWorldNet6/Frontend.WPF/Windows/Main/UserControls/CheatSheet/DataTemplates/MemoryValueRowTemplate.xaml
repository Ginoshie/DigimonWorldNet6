<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:models="clr-namespace:DigimonWorld.Frontend.WPF.Windows.Main.UserControls.CheatSheet.Models">

    <DataTemplate x:Key="MemoryValueRowTemplate" DataType="{x:Type models:MemoryValueViewModel}">
        <CheckBox IsChecked="{Binding Value}" Content="{Binding Label}"
                  Margin="3,3,0,1" Cursor="Hand"
                  Background="#2E3841" BorderBrush="#90D9FA">
            <CheckBox.Template>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" Background="Transparent">
                        <Border x:Name="Box"
                                Width="14" Height="14"
                                VerticalAlignment="Center"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1.5"
                                CornerRadius="2"
                                SnapsToDevicePixels="True">
                            <Border.LayoutTransform>
                                <ScaleTransform ScaleX="1.5" ScaleY="1.5" />
                            </Border.LayoutTransform>
                            <Rectangle x:Name="Fill"
                                       Margin="2"
                                       Fill="White"
                                       RadiusX="1"
                                       RadiusY="1"
                                       Visibility="Collapsed" />
                        </Border>
                        <ContentPresenter VerticalAlignment="Center" Margin="8,0,0,0" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Fill" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </CheckBox.Template>
        </CheckBox>
    </DataTemplate>

</ResourceDictionary>
