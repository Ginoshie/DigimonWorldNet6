<UserControl x:Class="DigimonWorld.Frontend.WPF.Windows.Main.UserControls.DigiWiki.UserControls.Navigation.Chapters.ConditionsChapter.ConditionTopicsMenuNavigation"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:navigationButtons="clr-namespace:DigimonWorld.Frontend.WPF.Windows.Main.UserControls.DigiWiki.UserControls.Navigation.NavigationButtons"
             xmlns:digiWiki="clr-namespace:DigimonWorld.Frontend.WPF.Windows.Main.UserControls.DigiWiki"
             xmlns:conversion="clr-namespace:DigimonWorld.Frontend.WPF.Conversion"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=digiWiki:DigiWikiViewModel, IsDesignTimeCreatable=True}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ResourceDictionaries/Styles/Labels/DefaultSheenLabelStyle.xaml" />
                <ResourceDictionary Source="/ResourceDictionaries/Styles/DefaultFocusStyle.xaml" />
                <ResourceDictionary Source="/ResourceDictionaries/Styles/ToolTips/DefaultTooltipRightStyle.xaml" />
                <ResourceDictionary Source="/ResourceDictionaries/Styles/Buttons/DefaultButtonStyle.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <conversion:StringEqualsToBoolConverter x:Key="StringEqualsToBoolConverter" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Image Grid.Row="0" Grid.Column="0" Height="40"
               Source="/Images/Icons/Labels/topics-label.png"
               Margin="0,25, 0, 15" />
        <WrapPanel Grid.Row="1" HorizontalAlignment="Center">
            <navigationButtons:HungryTopicNavigationButton Command="{Binding OpenHungryTopicCommand}"
                IsActive="{Binding ActiveTopic, Converter={StaticResource StringEqualsToBoolConverter}, ConverterParameter=Hungry}" />
            <navigationButtons:PoopyTopicNavigationButton Command="{Binding OpenPoopyTopicCommand}"
                IsActive="{Binding ActiveTopic, Converter={StaticResource StringEqualsToBoolConverter}, ConverterParameter=Poopy}" />
            <navigationButtons:TiredTopicNavigationButton Command="{Binding OpenTiredTopicCommand}"
                IsActive="{Binding ActiveTopic, Converter={StaticResource StringEqualsToBoolConverter}, ConverterParameter=Tired}" />
            <navigationButtons:SleepyTopicNavigationButton Command="{Binding OpenSleepyTopicCommand}"
                IsActive="{Binding ActiveTopic, Converter={StaticResource StringEqualsToBoolConverter}, ConverterParameter=Sleepy}" />
            <navigationButtons:FlowerTopicNavigationButton Command="{Binding OpenFlowerTopicCommand}"
                IsActive="{Binding ActiveTopic, Converter={StaticResource StringEqualsToBoolConverter}, ConverterParameter=Flower}" />
            <navigationButtons:InjuredTopicNavigationButton Command="{Binding OpenInjuryTopicCommand}"
                IsActive="{Binding ActiveTopic, Converter={StaticResource StringEqualsToBoolConverter}, ConverterParameter=Injured}" />
            <navigationButtons:SickTopicNavigationButton Command="{Binding OpenSickTopicCommand}"
                IsActive="{Binding ActiveTopic, Converter={StaticResource StringEqualsToBoolConverter}, ConverterParameter=Sick}" />
        </WrapPanel>
        <Button Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Bottom" FocusVisualStyle="{StaticResource DefaultFocusStyle}"
                Style="{StaticResource DefaultButtonStyle}"
                Margin="0,20, 0, 20"
                Padding="10"
                Content="Back to chapters"
                Command="{Binding OpenChaptersCommand}">
            <Button.ToolTip>
                <ToolTip Style="{StaticResource DefaultToolTipRightStyle}" Content="Navigate back to the wiki chapters" />
            </Button.ToolTip>
        </Button>
    </Grid>
</UserControl>