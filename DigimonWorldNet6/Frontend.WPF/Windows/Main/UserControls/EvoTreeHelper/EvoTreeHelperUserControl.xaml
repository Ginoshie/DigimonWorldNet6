<UserControl x:Class="DigimonWorld.Frontend.WPF.Windows.Main.UserControls.EvoTreeHelper.EvoTreeHelperUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:evoTreeHelper="clr-namespace:DigimonWorld.Frontend.WPF.Windows.Main.UserControls.EvoTreeHelper"
             xmlns:converters="clr-namespace:DigimonWorld.Frontend.WPF.Windows.Main.UserControls.EvoTreeHelper.Converters"
             xmlns:uc="clr-namespace:DigimonWorld.Frontend.WPF.Windows.Main.UserControls.EvoTreeHelper.UserControls"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:system="clr-namespace:System;assembly=System.Runtime"
             Height="565"
             Width="1093"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=evoTreeHelper:EvoTreeHelperViewModel, IsDesignTimeCreatable=True}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../../../ResourceDictionaries/Styles/Buttons/StretchContentButtonStyle.xaml" />
                <ResourceDictionary Source="/Frontend.WPF;component/Windows/Main/UserControls/EvoTreeHelper/Styles/SelectableStretchContentButtonStyle.xaml" />
                <ResourceDictionary Source="../../../../ResourceDictionaries/Styles/ToolTips/DefaultTooltipRightStyle.xaml" />
                <ResourceDictionary Source="../../../../ResourceDictionaries/Styles/DefaultReadonlyTextboxStyle.xaml" />
                <ResourceDictionary Source="/ResourceDictionaries/Styles/Labels/DefaultLabelStyle.xaml" />
            </ResourceDictionary.MergedDictionaries>
            
            <converters:DiagonalPathConverter x:Key="DiagonalPathConverter" />
            
            <sys:Double x:Key="NodeSize">46</sys:Double>
            <sys:Double x:Key="HeaderIconSize">40</sys:Double>
            <system:Double x:Key="FontSizeUserStats">11</system:Double>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border CornerRadius="8" BorderBrush="#90D9FA" BorderThickness="3" Background="#2E3841">
        <Border CornerRadius="5" BorderBrush="Black" BorderThickness="3" Background="#2E3841" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Gabumon narrator area (top left) -->
                <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0" Source="/Images/Icons/Narrators/Gabumon.png" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,5, 10,5"
                           Height="180"
                           RenderTransformOrigin="0.5,0.5">
                    </Image>

                    <Border Grid.Column="1" CornerRadius="8" BorderBrush="Black" BorderThickness="3" Margin="0,5,0,5" Padding="0" Background="Black" VerticalAlignment="Stretch"
                            HorizontalAlignment="Stretch">
                        <Border CornerRadius="8" BorderBrush="#4A9FC5" BorderThickness="3" Padding="0" Background="#4A9FC5">
                            <Border CornerRadius="5" BorderBrush="#90D9FA" BorderThickness="3" Padding="0" Background="#2E3841">
                                <Border CornerRadius="5" BorderBrush="Transparent" BorderThickness="0" Padding="0" Background="#77000000">
                                    <Border.InputBindings>
                                        <MouseBinding Gesture="LeftClick" Command="{Binding InstantDisplayCommand}" />
                                    </Border.InputBindings>
                                    <StackPanel Margin="5">
                                        <TextBlock Text="Gabumon"
                                                   Foreground="#D4D604"
                                                   FontSize="15"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Top"
                                                   Margin="0,5,0,5"
                                                   TextWrapping="Wrap" />
                                        <TextBlock
                                            Text="{Binding GabumonText}"
                                            Foreground="#B3B5B1"
                                            FontSize="14"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            Margin="0,5"
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </Border>
                        </Border>
                    </Border>
                </Grid>

                <!-- Evolution tree (left side, vertically centered within textbox rows) -->
                <Grid Grid.Row="1" Grid.Column="0" x:Name="CanvasHost">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Canvas Grid.Row="0" Width="{Binding CanvasWidth}" Height="{Binding CanvasHeight}" VerticalAlignment="Center">

                        <!-- Connection lines (rendered behind nodes) -->
                        <ItemsControl ItemsSource="{Binding Connections}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type evoTreeHelper:ResolvedConnection}">
                                    <Canvas>
                                        <!-- Dark outer stroke -->
                                        <Path Stroke="{Binding DarkStroke}"
                                              StrokeThickness="6"
                                              Fill="Transparent">
                                            <Path.Data>
                                                <MultiBinding Converter="{StaticResource DiagonalPathConverter}" ConverterParameter="46">
                                                    <Binding Path="Source.X" />
                                                    <Binding Path="Source.Y" />
                                                    <Binding Path="Target.X" />
                                                    <Binding Path="Target.Y" />
                                                    <Binding Path="SourceYOffset" />
                                                    <Binding Path="StubTier" />
                                                </MultiBinding>
                                            </Path.Data>
                                        </Path>
                                        <!-- Light inner stroke -->
                                        <Path Stroke="{Binding Stroke}"
                                              StrokeThickness="2"
                                              Fill="Transparent">
                                            <Path.Data>
                                                <MultiBinding Converter="{StaticResource DiagonalPathConverter}" ConverterParameter="46">
                                                    <Binding Path="Source.X" />
                                                    <Binding Path="Source.Y" />
                                                    <Binding Path="Target.X" />
                                                    <Binding Path="Target.Y" />
                                                    <Binding Path="SourceYOffset" />
                                                    <Binding Path="StubTier" />
                                                </MultiBinding>
                                            </Path.Data>
                                        </Path>
                                    </Canvas>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Nodes (rendered on top of connections) -->
                        <ItemsControl ItemsSource="{Binding Nodes}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding X}" />
                                    <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="{StaticResource NodeSize}" Height="{StaticResource NodeSize}"
                                            Style="{StaticResource SelectableStretchContentButtonStyle}"
                                            Tag="{Binding IsSelected}"
                                            Focusable="False"
                                            ToolTipService.InitialShowDelay="{StaticResource DefaultTooltipDelay}"
                                            RenderOptions.BitmapScalingMode="HighQuality">
                                        <Button.ToolTip>
                                            <ToolTip Style="{StaticResource DefaultToolTipRightStyle}">
                                                <TextBlock Text="{Binding DigimonName}" />
                                            </ToolTip>
                                        </Button.ToolTip>
                                        <Image Source="{Binding IconPath}" Stretch="Fill" />
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </Canvas>

                    <!-- Special Evolutions -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5,5,0,0">
                        <TextBlock Text="Special evo:" Foreground="#D4D604" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <ItemsControl ItemsSource="{Binding SpecialEvolutions}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="36" Height="36" Margin="2,0"
                                            Style="{StaticResource DisplayOnlyStretchContentButtonStyle}"
                                            ToolTipService.InitialShowDelay="200"
                                            RenderOptions.BitmapScalingMode="HighQuality">
                                        <Button.ToolTip>
                                            <ToolTip Style="{StaticResource DefaultToolTipRightStyle}" MaxWidth="260">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#D4D604" Margin="0,0,0,4" />
                                                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Foreground="#B3B5B1" />
                                                </StackPanel>
                                            </ToolTip>
                                        </Button.ToolTip>
                                        <Image Source="{Binding IconPath}" Stretch="Fill" />
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="0" Grid.Column="1" Grid.RowSpan="2">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Image Grid.Row="0" Height="40" HorizontalAlignment="Center"
                           Source="/Images/Icons/Labels/evolutions-label.png"
                           Margin="60,0, 0, 10" />

                    <!-- Evolution criteria panel (right side) -->
                    <Grid x:Name="CriteriaGrid" Grid.Row="1" Grid.IsSharedSizeScope="True" VerticalAlignment="Bottom">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="44" SharedSizeGroup="Row0" />
                            <RowDefinition SharedSizeGroup="Row1" />
                            <RowDefinition SharedSizeGroup="Row2" />
                            <RowDefinition SharedSizeGroup="Row3" />
                            <RowDefinition SharedSizeGroup="Row4" />
                            <RowDefinition SharedSizeGroup="Row5" />
                            <RowDefinition SharedSizeGroup="Row6" />
                            <RowDefinition SharedSizeGroup="Row7" />
                            <RowDefinition SharedSizeGroup="Row8" />
                            <RowDefinition SharedSizeGroup="Row9" />
                            <RowDefinition SharedSizeGroup="Row10" />
                            <RowDefinition SharedSizeGroup="Row11" />
                            <RowDefinition SharedSizeGroup="Row12" />
                            <RowDefinition SharedSizeGroup="Row13" />
                            <RowDefinition SharedSizeGroup="Row14" />
                        </Grid.RowDefinitions>

                        <!-- Row labels -->
                        <Label Grid.Row="0" Grid.Column="0" Style="{StaticResource DefaultLabelStyle}" Content="" Padding="2" Margin="0,1" Height="40" />
                        <Label Grid.Row="1" Grid.Column="0" Style="{StaticResource DefaultLabelStyle}" Content="Score:" Padding="2" Margin="0,1" />
                        <Label Grid.Row="2" Grid.Column="0" Style="{StaticResource DefaultLabelStyle}" Content="HP:" Padding="2" Margin="0,1" />
                        <Label Grid.Row="3" Grid.Column="0" Style="{StaticResource DefaultLabelStyle}" Content="MP:" Padding="2" Margin="0,1" />
                        <Label Grid.Row="4" Grid.Column="0" Style="{StaticResource DefaultLabelStyle}" Content="Off:" Padding="2" Margin="0,1" />
                        <Label Grid.Row="5" Grid.Column="0" Style="{StaticResource DefaultLabelStyle}" Content="Def:" Padding="2" Margin="0,1" />
                        <Label Grid.Row="6" Grid.Column="0" Style="{StaticResource DefaultLabelStyle}" Content="Speed:" Padding="2" Margin="0,1" />
                        <Label Grid.Row="7" Grid.Column="0" Style="{StaticResource DefaultLabelStyle}" Content="Brains:" Padding="2" Margin="0,1" />
                        <Label Grid.Row="8" Grid.Column="0" Style="{StaticResource DefaultLabelStyle}" Content="Weight:" Padding="2" Margin="0,1" />
                        <Label Grid.Row="9" Grid.Column="0" Style="{StaticResource DefaultLabelStyle}" Content="CM:" Padding="2" Margin="0,1" />
                        <Label Grid.Row="10" Grid.Column="0" Style="{StaticResource DefaultLabelStyle}" Content="Happy:" Padding="2" Margin="0,1" />
                        <Label Grid.Row="11" Grid.Column="0" Style="{StaticResource DefaultLabelStyle}" Content="Disc:" Padding="2" Margin="0,1" />
                        <Label Grid.Row="12" Grid.Column="0" Style="{StaticResource DefaultLabelStyle}" Content="Battles:" Padding="2" Margin="0,1" />
                        <Label Grid.Row="13" Grid.Column="0" Style="{StaticResource DefaultLabelStyle}" Content="Techs:" Padding="2" Margin="0,1" />
                        <Label Grid.Row="14" Grid.Column="0" Style="{StaticResource DefaultLabelStyle}" Content="Digimon:" Padding="2" Margin="0,1" />

                        <!-- Current stats column -->
                        <Button Grid.Row="0" Grid.Column="1" Width="{StaticResource HeaderIconSize}" Height="{StaticResource HeaderIconSize}" HorizontalAlignment="Center"
                                Style="{StaticResource DisplayOnlyStretchContentButtonStyle}"
                                ToolTipService.InitialShowDelay="{StaticResource DefaultTooltipDelay}"
                                RenderOptions.BitmapScalingMode="HighQuality" Margin="2,0,2,4">
                            <Button.ToolTip>
                                <ToolTip Style="{StaticResource DefaultToolTipRightStyle}">
                                    <TextBlock Text="{Binding CurrentDigimonName}" />
                                </ToolTip>
                            </Button.ToolTip>
                            <Image Source="{Binding CurrentIconPath}" Stretch="Fill" />
                        </Button>
                        <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource DefaultReadonlyTextBoxStyle}" FontSize="{StaticResource FontSizeUserStats}" Text="{Binding CurrentHp, Mode=OneWay}" HorizontalContentAlignment="Center"
                                 Margin="2,1" />
                        <TextBox Grid.Row="3" Grid.Column="1" Style="{StaticResource DefaultReadonlyTextBoxStyle}" FontSize="{StaticResource FontSizeUserStats}" Text="{Binding CurrentMp, Mode=OneWay}" HorizontalContentAlignment="Center"
                                 Margin="2,1" />
                        <TextBox Grid.Row="4" Grid.Column="1" Style="{StaticResource DefaultReadonlyTextBoxStyle}" FontSize="{StaticResource FontSizeUserStats}" Text="{Binding CurrentOff, Mode=OneWay}" HorizontalContentAlignment="Center"
                                 Margin="2,1" />
                        <TextBox Grid.Row="5" Grid.Column="1" Style="{StaticResource DefaultReadonlyTextBoxStyle}" FontSize="{StaticResource FontSizeUserStats}" Text="{Binding CurrentDef, Mode=OneWay}" HorizontalContentAlignment="Center"
                                 Margin="2,1" />
                        <TextBox Grid.Row="6" Grid.Column="1" Style="{StaticResource DefaultReadonlyTextBoxStyle}" FontSize="{StaticResource FontSizeUserStats}" Text="{Binding CurrentSpeed, Mode=OneWay}" HorizontalContentAlignment="Center"
                                 Margin="2,1" />
                        <TextBox Grid.Row="7" Grid.Column="1" Style="{StaticResource DefaultReadonlyTextBoxStyle}" FontSize="{StaticResource FontSizeUserStats}" Text="{Binding CurrentBrains, Mode=OneWay}" HorizontalContentAlignment="Center"
                                 Margin="2,1" />
                        <TextBox Grid.Row="8" Grid.Column="1" Style="{StaticResource DefaultReadonlyTextBoxStyle}" FontSize="{StaticResource FontSizeUserStats}" Text="{Binding CurrentWeight, Mode=OneWay}" HorizontalContentAlignment="Center"
                                 Margin="2,1" />
                        <TextBox Grid.Row="9" Grid.Column="1" Style="{StaticResource DefaultReadonlyTextBoxStyle}" FontSize="{StaticResource FontSizeUserStats}" Text="{Binding CurrentCareMistakes, Mode=OneWay}"
                                 HorizontalContentAlignment="Center"
                                 Margin="2,1" />
                        <TextBox Grid.Row="10" Grid.Column="1" Style="{StaticResource DefaultReadonlyTextBoxStyle}" FontSize="{StaticResource FontSizeUserStats}" Text="{Binding CurrentHappiness, Mode=OneWay}" HorizontalContentAlignment="Center"
                                 Margin="2,1" />
                        <TextBox Grid.Row="11" Grid.Column="1" Style="{StaticResource DefaultReadonlyTextBoxStyle}" FontSize="{StaticResource FontSizeUserStats}" Text="{Binding CurrentDiscipline, Mode=OneWay}" HorizontalContentAlignment="Center"
                                 Margin="2,1" />
                        <TextBox Grid.Row="12" Grid.Column="1" Style="{StaticResource DefaultReadonlyTextBoxStyle}" FontSize="{StaticResource FontSizeUserStats}" Text="{Binding CurrentBattles, Mode=OneWay}" HorizontalContentAlignment="Center"
                                 Margin="2,1" />
                        <TextBox Grid.Row="13" Grid.Column="1" Style="{StaticResource DefaultReadonlyTextBoxStyle}" FontSize="{StaticResource FontSizeUserStats}" Text="{Binding CurrentTechniqueCount, Mode=OneWay}"
                                 HorizontalContentAlignment="Center"
                                 Margin="2,1" />

                        <!-- Criteria columns -->
                        <uc:CriteriaColumnUserControl Grid.Row="0" Grid.RowSpan="15" Grid.Column="2" DataContext="{Binding Evolution1}" Width="80" />
                        <uc:CriteriaColumnUserControl Grid.Row="0" Grid.RowSpan="15" Grid.Column="3" DataContext="{Binding Evolution2}" Width="80" />
                        <uc:CriteriaColumnUserControl Grid.Row="0" Grid.RowSpan="15" Grid.Column="4" DataContext="{Binding Evolution3}" Width="80" />
                        <uc:CriteriaColumnUserControl Grid.Row="0" Grid.RowSpan="15" Grid.Column="5" DataContext="{Binding Evolution4}" Width="80" />
                        <uc:CriteriaColumnUserControl Grid.Row="0" Grid.RowSpan="15" Grid.Column="6" DataContext="{Binding Evolution5}" Width="80" />
                        <uc:CriteriaColumnUserControl Grid.Row="0" Grid.RowSpan="15" Grid.Column="7" DataContext="{Binding Evolution6}" Width="80" />
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Border>
</UserControl>